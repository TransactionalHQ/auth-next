{
  "name": "@usetransactional/auth-next",
  "version": "0.1.0",
  "description": "Next.js SDK for Transactional Auth - OpenID Connect authentication for Next.js applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.mjs",
      "require": "./dist/middleware/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client/index.ts src/server/index.ts src/middleware/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/client/index.ts src/server/index.ts src/middleware/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "next",
    "nextjs",
    "react",
    "auth",
    "authentication",
    "oidc",
    "openid-connect",
    "oauth2",
    "transactional",
    "app-router",
    "server-components"
  ],
  "author": "Transactional",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TransactionalHQ/auth-next.git"
  },
  "homepage": "https://github.com/TransactionalHQ/auth-next#readme",
  "bugs": {
    "url": "https://github.com/TransactionalHQ/auth-next/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
